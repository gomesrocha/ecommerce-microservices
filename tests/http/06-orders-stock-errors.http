### ============================================================
### 06-orders-stock-errors.http
### Testes de rejeição por estoque insuficiente
###
### Pré-requisito:
### - Executar 00-auth.http antes para salvar access_token
### ============================================================

@gateway = http://localhost:8099
@sku = HTTP-STOCK-{{$timestamp}}


### ------------------------------------------------------------
### 1. Garantir rota de entrega SP -> SE
### ------------------------------------------------------------
PUT {{gateway}}/api/delivery-estimates/routes
Content-Type: application/json
Authorization: Bearer {{access_token}}

{
  "originState": "SP",
  "destinationState": "SE",
  "minDays": 5,
  "estimatedDays": 8,
  "maxDays": 13,
  "source": "MANUAL_BASELINE",
  "modelVersion": "baseline-routes-v1"
}


### ------------------------------------------------------------
### 2. Criar produto com estoque baixo
### Salva:
### - low_stock_product_id
### ------------------------------------------------------------
# @name createLowStockProduct
POST {{gateway}}/api/products
Content-Type: application/json
Authorization: Bearer {{access_token}}

{
  "name": "Produto Estoque Baixo HTTP",
  "description": "Produto para testar rejeição por estoque",
  "sku": "{{sku}}",
  "price": 100.00,
  "stockQuantity": 1,
  "originState": "SP"
}

> {%
    client.global.set("low_stock_product_id", response.body.id);
%}


### ------------------------------------------------------------
### 3. Criar pedido com quantidade maior que o estoque
### Salva:
### - stock_rejected_order_id
### Esperado inicial:
### - WAITING_STOCK
### ------------------------------------------------------------
# @name createStockRejectedOrder
POST {{gateway}}/api/orders
Content-Type: application/json
Authorization: Bearer {{access_token}}

{
  "userId": 1,
  "customerState": "SE",
  "items": [
    {
      "productId": {{low_stock_product_id}},
      "quantity": 10
    }
  ]
}

> {%
    client.global.set("stock_rejected_order_id", response.body.id);
%}


### ------------------------------------------------------------
### 4. Consultar pedido rejeitado por estoque
### Observação:
### - Aguarde 1 a 3 segundos antes de executar.
### Esperado:
### - status = REJECTED
### - stockReason = Estoque insuficiente...
### ------------------------------------------------------------
GET {{gateway}}/api/orders/{{stock_rejected_order_id}}
Authorization: Bearer {{access_token}}


### ------------------------------------------------------------
### 5. Consultar histórico do pedido
### Esperado:
### - ORDER_CREATED
### - STOCK_REJECTED
### ------------------------------------------------------------
GET {{gateway}}/api/orders/{{stock_rejected_order_id}}/history
Authorization: Bearer {{access_token}}
