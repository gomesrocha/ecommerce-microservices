USER_API_DB_PASSWORD=ecommerce
USER_API_JWT_ISSUER=user-api
USER_API_ACCESS_TOKEN_MINUTES=30
USER_API_REFRESH_TOKEN_MINUTES=10080

# RabbitMQ
RABBITMQ_DEFAULT_USER=ecommerce
RABBITMQ_DEFAULT_PASS=ecommerce
