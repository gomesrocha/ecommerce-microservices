{
  "$schema": "https://www.krakend.io/schema/krakend.json",
  "version": 3,
  "name": "ecommerce-api-gateway",
  "port": 8080,
  "timeout": "5000ms",
  "cache_ttl": "300s",
  "output_encoding": "no-op",
  "endpoints": [
    {
      "endpoint": "/api/ai/chat",
      "method": "POST",
      "output_encoding": "no-op",
      "input_headers": ["Content-Type", "Authorization"],
      "backend": [
        {
          "host": ["http://ai-chat-bff:8080"],
          "url_pattern": "/chat",
          "method": "POST",
          "encoding": "no-op"
        }
      ]
    },
    {
      "endpoint": "/api/notifications",
      "method": "POST",
      "output_encoding": "no-op",
      "input_headers": ["Content-Type", "Authorization"],
      "backend": [
        {
          "host": ["http://notification-service:8080"],
          "url_pattern": "/notifications",
          "method": "POST",
          "encoding": "no-op"
        }
      ]
    },
    {
      "endpoint": "/api/notifications/{id}",
      "method": "GET",
      "output_encoding": "no-op",
      "input_headers": ["Authorization"],
      "backend": [
        {
          "host": ["http://notification-service:8080"],
          "url_pattern": "/notifications/{id}",
          "method": "GET",
          "encoding": "no-op"
        }
      ]
    },
    {
      "endpoint": "/api/notifications/user/{userId}",
      "method": "GET",
      "output_encoding": "no-op",
      "input_headers": ["Authorization"],
      "backend": [
        {
          "host": ["http://notification-service:8080"],
          "url_pattern": "/notifications/user/{userId}",
          "method": "GET",
          "encoding": "no-op"
        }
      ]
    },
    {
      "endpoint": "/api/notifications/user/{userId}/unread",
      "method": "GET",
      "output_encoding": "no-op",
      "input_headers": ["Authorization"],
      "backend": [
        {
          "host": ["http://notification-service:8080"],
          "url_pattern": "/notifications/user/{userId}/unread",
          "method": "GET",
          "encoding": "no-op"
        }
      ]
    },
    {
      "endpoint": "/api/notifications/{id}/read",
      "method": "PUT",
      "output_encoding": "no-op",
      "input_headers": ["Authorization"],
      "backend": [
        {
          "host": ["http://notification-service:8080"],
          "url_pattern": "/notifications/{id}/read",
          "method": "PUT",
          "encoding": "no-op"
        }
      ]
    },
    {
      "endpoint": "/api/products",
      "method": "GET",
      "output_encoding": "no-op",
      "input_headers": ["Content-Type", "Authorization"],
      "input_query_strings": ["*"],
      "backend": [
        {
          "host": ["http://product-api:8080"],
          "url_pattern": "/products",
          "method": "GET",
          "encoding": "no-op"
        }
      ]
    },
    {
      "endpoint": "/api/products",
      "method": "POST",
      "output_encoding": "no-op",
      "input_headers": ["Content-Type", "Authorization"],
      "backend": [
        {
          "host": ["http://product-api:8080"],
          "url_pattern": "/products",
          "method": "POST",
          "encoding": "no-op"
        }
      ],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://user-api:8080/auth/.well-known/jwks.json",
          "issuer": "user-api",
          "cache": true,
          "cache_duration": 900,
          "disable_jwk_security": true,
          "propagate_claims": [
            ["sub", "X-User-Id"],
            ["groups", "X-User-Roles"]
          ]
        }
      }
    },
    {
      "endpoint": "/api/products/{id}",
      "method": "GET",
      "output_encoding": "no-op",
