{
  "$schema": "https://www.krakend.io/schema/krakend.json",
  "version": 3,
  "name": "ecommerce-api-gateway",
  "port": 8080,
  "timeout": "5000ms",
  "cache_ttl": "300s",
  "output_encoding": "no-op",
  "endpoints": [
    {
      "endpoint": "/api/products",
      "method": "GET",
      "output_encoding": "no-op",
      "input_headers": ["Content-Type", "Authorization"],
      "input_query_strings": ["*"],
      "backend": [
        {
          "host": ["http://product-api:8080"],
          "url_pattern": "/products",
          "method": "GET",
          "encoding": "no-op"
        }
      ]
    },
    {
      "endpoint": "/api/products",
      "method": "POST",
      "output_encoding": "no-op",
      "input_headers": ["Content-Type", "Authorization"],
      "backend": [
        {
          "host": ["http://product-api:8080"],
          "url_pattern": "/products",
          "method": "POST",
          "encoding": "no-op"
        }
      ]
    },
    {
      "endpoint": "/api/products/{id}",
      "method": "GET",
      "output_encoding": "no-op",
      "input_headers": ["Content-Type", "Authorization"],
      "backend": [
        {
          "host": ["http://product-api:8080"],
          "url_pattern": "/products/{id}",
          "method": "GET",
          "encoding": "no-op"
        }
      ]
    },
    {
      "endpoint": "/api/products/{id}",
      "method": "PUT",
      "output_encoding": "no-op",
      "input_headers": ["Content-Type", "Authorization"],
      "backend": [
        {
          "host": ["http://product-api:8080"],
          "url_pattern": "/products/{id}",
          "method": "PUT",
          "encoding": "no-op"
        }
      ]
    },
    {
      "endpoint": "/api/products/{id}/deactivate",
      "method": "PATCH",
      "output_encoding": "no-op",
      "input_headers": ["Content-Type", "Authorization"],
      "backend": [
        {
          "host": ["http://product-api:8080"],
          "url_pattern": "/products/{id}/deactivate",
          "method": "PATCH",
          "encoding": "no-op"
        }
      ]
    },
    {
      "endpoint": "/api/orders",
      "method": "GET",
      "output_encoding": "no-op",
      "input_headers": ["Content-Type", "Authorization"],
      "input_query_strings": ["*"],
      "backend": [
        {
          "host": ["http://order-api:8080"],
          "url_pattern": "/orders",
          "method": "GET",
          "encoding": "no-op"
        }
      ]
    },
    {
      "endpoint": "/api/orders",
      "method": "POST",
      "output_encoding": "no-op",
      "input_headers": ["Content-Type", "Authorization"],
      "backend": [
        {
          "host": ["http://order-api:8080"],
          "url_pattern": "/orders",
          "method": "POST",
          "encoding": "no-op"
        }
      ]
    },
    {
      "endpoint": "/api/orders/{id}",
      "method": "GET",
      "output_encoding": "no-op",
      "input_headers": ["Content-Type", "Authorization"],
      "backend": [
        {
          "host": ["http://order-api:8080"],
          "url_pattern": "/orders/{id}",
          "method": "GET",
          "encoding": "no-op"
        }
      ]
    },
    {
      "endpoint": "/api/orders/{id}/history",
      "method": "GET",
      "output_encoding": "no-op",
      "input_headers": ["Content-Type", "Authorization"],
      "backend": [
        {
          "host": ["http://order-api:8080"],
          "url_pattern": "/orders/{id}/history",
          "method": "GET",
          "encoding": "no-op"
        }
      ]
    },
    {
      "endpoint": "/api/orders/{id}/cancel",
      "method": "PATCH",
      "output_encoding": "no-op",
      "input_headers": ["Content-Type", "Authorization"],
      "backend": [
        {
          "host": ["http://order-api:8080"],
          "url_pattern": "/orders/{id}/cancel",
          "method": "PATCH",
          "encoding": "no-op"
        }
      ]
    },
    {
      "endpoint": "/api/delivery-estimates/estimate",
      "method": "POST",
      "output_encoding": "no-op",
      "input_headers": ["Content-Type", "Authorization"],
      "backend": [
        {
          "host": ["http://delivery-estimator-api:8080"],
          "url_pattern": "/delivery-estimates/estimate",
          "method": "POST",
          "encoding": "no-op"
        }
      ]
    },
    {
      "endpoint": "/api/delivery-estimates/routes",
      "method": "GET",
      "output_encoding": "no-op",
      "input_headers": ["Content-Type", "Authorization"],
      "backend": [
        {
          "host": ["http://delivery-estimator-api:8080"],
          "url_pattern": "/delivery-estimates/routes",
          "method": "GET",
          "encoding": "no-op"
        }
      ]
    },
    {
      "endpoint": "/api/delivery-estimates/routes",
      "method": "PUT",
      "output_encoding": "no-op",
      "input_headers": ["Content-Type", "Authorization"],
      "backend": [
        {
          "host": ["http://delivery-estimator-api:8080"],
          "url_pattern": "/delivery-estimates/routes",
          "method": "PUT",
          "encoding": "no-op"
        }
      ]
    },
    {
      "endpoint": "/api/fraud-analyses",
      "method": "GET",
      "output_encoding": "no-op",
      "input_headers": ["Content-Type", "Authorization"],
      "backend": [
        {
          "host": ["http://fraud-detector-api:8080"],
          "url_pattern": "/fraud-analyses",
          "method": "GET",
          "encoding": "no-op"
        }
      ]
    },
    {
      "endpoint": "/api/fraud-analyses/order/{orderId}",
      "method": "GET",
      "output_encoding": "no-op",
      "input_headers": ["Content-Type", "Authorization"],
      "backend": [
        {
          "host": ["http://fraud-detector-api:8080"],
          "url_pattern": "/fraud-analyses/order/{orderId}",
          "method": "GET",
          "encoding": "no-op"
        }
      ]
    }
  ]
}
